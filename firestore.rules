
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "s55uL0f8PmcypR75usVYOLwVs7O2" ||
        request.auth.token.email == "chetanmadhav4@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }

      // Allow creating chat messages for the user
      match /chatMessages/{msgId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Fund Requests: Root level rules for cleaner access
    match /fundRequests/{requestId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || request.query.limit <= 100);
      allow update, delete: if isAdmin();
    }

    // Wallet redeem codes
    match /redeemCodes/{codeId} {
      allow read: if isSignedIn();
      allow create, delete: if isAdmin();
      // Allow users to update ONLY usage-related fields during redemption
      allow update: if isSignedIn() && (
        isAdmin() || 
        (
          request.resource.data.amount == resource.data.amount &&
          request.resource.data.limit == resource.data.limit &&
          request.resource.data.usedCount == resource.data.usedCount + 1 &&
          request.resource.data.usedBy.hasAll(resource.data.usedBy) &&
          request.auth.uid in request.resource.data.usedBy
        )
      );
    }

    // Global announcements
    match /globalAnnouncements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings & Services
    match /globalSettings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection Group rules for advanced tracking
    match /{path=**}/orders/{orderId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }
  }
}
