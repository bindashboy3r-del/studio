
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "s55uL0f8PmcypR75usVYOLwVs7O2" ||
        request.auth.token.email == "chetanmadhav4@gmail.com"
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /chatMessages/{msgId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    // Fund Requests: Optimized for list/get permissions
    match /fundRequests/{requestId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || request.query.limit <= 100);
      allow update, delete: if isAdmin();
    }

    // Wallet redeem codes
    match /redeemCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Global announcements
    match /globalAnnouncements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Settings & Services
    match /globalSettings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection Group rule for Admin/User cross-access
    match /{path=**}/orders/{orderId} {
      allow read: if isSignedIn() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
    }
  }
}
