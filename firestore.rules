rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements a strict Path-Based Ownership model supplemented by a 
     * Global Administrative Access model based on email identification for simplicity
     * in this specific admin deployment.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** 
     * @description Identifies if the user is the specific admin provided.
     * Use roles_admin collection for more scalable RBAC in production.
     */
    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "chetanmadhav4@gmail.com";
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId}/chatMessages/{chatMessageId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /** 
     * Support for collectionGroup queries (e.g., fetching all orders in Admin Dashboard)
     */
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
  }
}
