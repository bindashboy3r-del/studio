rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict path-based ownership model combined with role-based access control 
     * (RBAC) via an administrative roles collection. User data is isolated within private subtrees 
     * where the path segment {userId} must match the authenticated user's UID.
     * 
     * DATA STRUCTURE
     * - /users/{userId}: Private user profiles.
     * - /users/{userId}/messages/{messageId}: Private user-bot chat history.
     * - /users/{userId}/orders/{orderId}: Private user orders (also accessible by admins).
     * - /services/{serviceId}: Publicly readable service definitions, admin-managed.
     * - /roles_admin/{userId}: Indicator collection for administrative privileges.
     * 
     * KEY SECURITY DECISIONS
     * - Authorization Independence: We rely on the {userId} in the path as the primary authority.
     * - DBAC (Database Access Control): Admin status is determined by document existence in /roles_admin.
     * - Relational Integrity: On creation, documents must include a field (e.g., userId or id) 
     *   that matches the path ID to ensure data consistency.
     * - Denormalization for Authorization: The userId is stored within documents to support 
     *   potential future collection group queries and to maintain entity integrity.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated with Firebase Auth. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the provided userId matches the authenticated user's UID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the authenticated user has an entry in the roles_admin collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Combines ownership check with a verification that the document exists. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the User profile entity. Users can manage their own profile.
     * @path /users/{userId}
     * @allow Authenticated user (create) where request.resource.data.id == userId.
     * @deny Any user (update) attempting to change their internal 'id' field.
     * @principle Enforces path-based ownership and relational integrity for user profiles.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for chat messages between users and the bot.
     * @path /users/{userId}/messages/{messageId}
     * @allow User 'abc' (list) their own messages at /users/abc/messages.
     * @deny User 'abc' (get) a message belonging to user 'xyz'.
     * @principle Subcollection isolation ensures users only see their own chat history.
     */
    match /users/{userId}/messages/{messageId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rules for service orders. Private to users, but readable/updatable by admins.
     * @path /users/{userId}/orders/{orderId}
     * @allow Admin (update) the status of any order.
     * @deny User 'abc' (create) an order with a 'userId' field matching 'xyz'.
     * @principle Dual-access model (Owner + Admin) for transactional data.
     */
    match /users/{userId}/orders/{orderId} {
      allow get, list: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if (isExistingOwner(userId) || isAdmin()) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    /**
     * @description Publicly readable collection of SMM services.
     * @path /services/{serviceId}
     * @allow Anonymous user (get) a service description.
     * @deny Authenticated non-admin user (create) a new service.
     * @principle Public read with role-restricted writes for global configuration data.
     */
    match /services/{serviceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    /**
     * @description Administrative roles indicator collection.
     * @path /roles_admin/{userId}
     * @allow Signed-in user (get) their own admin status.
     * @deny User (list) all admins unless they are themselves an admin.
     * @principle DBAC (Database Access Control) mapping for global roles.
     */
    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if false; // Managed via Admin SDK or Cloud Functions
    }

    // --- Collection Group Rules ---

    /**
     * @description Collection group for orders to allow administrative overview.
     * @path /{path=**}/orders/{orderId}
     * @allow Admin (list) all orders across the entire database.
     * @deny Regular user (list) all orders.
     * @principle Supports cross-user administrative queries while maintaining security.
     */
    match /{path=**}/orders/{orderId} {
      allow read, write: if isAdmin();
    }
  }
}