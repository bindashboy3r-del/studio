
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == "s55uL0f8PmcypR75usVYOLwVs7O2" ||
        request.auth.token.email == "chetanmadhav4@gmail.com"
      );
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/orders/{orderId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId}/chatMessages/{chatMessageId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /fundRequests/{requestId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /redeemCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /globalAnnouncements/{announcementId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /globalSettings/{settingsId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Collection group rules for nested user data (Admin Tracker)
    match /{path=**}/orders/{orderId} {
      allow read: if isAdmin();
    }
  }
}
