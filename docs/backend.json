
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user account in SocialBoost.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "balance": { "type": "number", "default": 0 },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "createdAt"]
    },
    "FundRequest": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "FundRequest",
      "type": "object",
      "description": "A request by a user to add money to their wallet.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "utrId": { "type": "string" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "amount", "utrId", "status", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "User profile and balance."
        }
      },
      {
        "path": "/fundRequests/{requestId}",
        "definition": {
          "entityName": "FundRequest",
          "schema": { "$ref": "#/backend/entities/FundRequest" },
          "description": "Global fund addition requests."
        }
      }
    ]
  }
}
